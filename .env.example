# ===== Порт, на котором поднимется приложение =====
APP_PORT=8000

# ===== Безопасность =====
# Длинная случайная строка. Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

# ===== Первый администратор (создаётся автоматически при первом запуске) =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=admin@example.com

# ===== SMTP — общий почтовый сервер для отправки напоминаний =====
# Пример для Gmail: smtp.gmail.com / 587 / TLS + пароль приложения.
# Пример для Яндекс: smtp.yandex.ru / 465 / SSL.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Важно: адрес в SMTP_FROM должен совпадать с SMTP_USER (ящик аутентификации),
# иначе Яндекс/Gmail отклонят письмо (553 Sender address rejected).
SMTP_FROM=Planner Pay <your-mailbox@yandex.ru>
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ===== Планировщик напоминаний =====
TIMEZONE=Europe/Moscow
REMINDER_HOUR=9
REMINDER_MINUTE=0

# ===== Прочее =====
CURRENCY=₽
APP_NAME=Planner Pay

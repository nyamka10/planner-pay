# Секреты и окружение
.env

# База данных (бинд-маунт ./data)
*.db
*.db-journal
*.db-wal
*.db-shm
data/*
!data/.gitkeep

# SSL-сертификаты и ключи Let's Encrypt (секреты!)
certbot/conf/*
certbot/www/*
!certbot/conf/.gitkeep
!certbot/www/.gitkeep

# Python
__pycache__/
*.pyc
.venv/
venv/

# Прочее
.DS_Store
smoketest.db
